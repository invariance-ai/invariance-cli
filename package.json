{
  "name": "@invariance/cli",
  "version": "0.1.0",
  "description": "The official Invariance AI command-line interface",
  "type": "module",
  "bin": {
    "invariance": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "invariance",
    "cli",
    "ai",
    "monitoring",
    "observability"
  ],
  "author": "Invariance AI <hello@invariance.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/invariance-ai/invariance-cli.git"
  },
  "homepage": "https://github.com/invariance-ai/invariance-cli#readme",
  "bugs": {
    "url": "https://github.com/invariance-ai/invariance-cli/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
